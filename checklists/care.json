{
  "name": "CARE",
  "full_name": "CAse REport Guidelines",
  "description": "Checklist for case reports (CARE 2013, updated 2017)",
  "version": "2017",
  "items": [
    {
      "section": "Title",
      "item": "1",
      "description": "The words 'case report' in the title along with the area of focus",
      "keywords": [
        "case report",
        "case of",
        "a rare case",
        "an unusual case",
        "a unique case",
        "novel case",
        "first reported case",
        "we report a case"
      ],
      "weight": 1.8,
      "notes": "Title should clearly identify as a case report"
    },
    {
      "section": "Key Words",
      "item": "2",
      "description": "2 to 5 key words that identify diagnoses or interventions in this case report",

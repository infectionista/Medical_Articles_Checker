{
  "name": "JBI_CASE_SERIES",
  "full_name": "JBI Critical Appraisal Checklist for Case Series",
  "description": "Critical appraisal checklist for case series studies",
  "version": "1.0",
  "items": [
    {
      "section": "Participant Selection",
      "item": "1",
      "description": "Were there clear criteria for inclusion in the case series?",
      "keywords": [
        "inclusion criteria",
        "eligibility criteria",
        "consecutive patients",
        "cases were selected",
        "patients were included",
        "selection criteria",
        "case definition",
        "entry criteria",
        "study population",
        "participant selection",
        "sampling method",
        "recruitment criteria",
        "enrolled subjects"
      ],
      "weight": 1.8,
      "notes": "Clear inclusion criteria are essential for determining the scope and generalizability of the case series"
    },
    {
      "section": "Measurement and Diagnosis",
      "item": "2",
      "description": "Was the condition measured in a standard, reliable way for all participants?",
      "keywords": [
        "diagnosis was confirmed",
        "diagnostic criteria",
        "histologically confirmed",
        "radiologically confirmed",
        "standard protocol",
        "consistent measurement",
        "standardized assessment",
        "validated instrument",
        "diagnostic procedure",
        "confirmed diagnosis",
        "objective measurement",
        "reproducible method",
        "uniform assessment"
      ],
      "weight": 1.9,
      "notes": "Standardization across all participants ensures consistency and reliability of reported findings"
    },
    {
      "section": "Measurement and Diagnosis",
      "item": "3",
      "description": "Were valid methods used for identification of the condition for all participants?",
      "keywords": [
        "validated method",
        "gold standard",
        "reference standard",
        "confirmatory testing",
        "established criteria",
        "diagnostic validity",
        "appropriate tests",
        "valid diagnosis",
        "proper diagnostic",
        "recognized criteria",
        "objective criteria",
        "pathological confirmation"
      ],
      "weight": 1.9,
      "notes": "Use of valid methods strengthens the credibility of the diagnosis and subsequent findings"
    },
    {
      "section": "Participant Selection",
      "item": "4",
      "description": "Did the case series have consecutive inclusion of participants?",
      "keywords": [
        "consecutive patients",
        "consecutive cases",
        "consecutively enrolled",
        "consecutive referrals",
        "all patients presenting",
        "consecutive series",
        "sequential enrollment",
        "unselected cases",
        "prospective recruitment",
        "systematic enrollment",
        "chronological order",
        "consecutive admissions"
      ],
      "weight": 1.7,
      "notes": "Consecutive inclusion reduces selection bias and improves the representativeness of the sample"
    },
    {
      "section": "Participant Selection",
      "item": "5",
      "description": "Did the case series have complete inclusion of participants?",
      "keywords": [
        "all patients",
        "complete enrollment",
        "no exclusions",
        "all eligible",
        "entire cohort",
        "complete sample",
        "all cases",
        "unselected patients",
        "complete participation",
        "fully enrolled",
        "no participants excluded",
        "total patient cohort"
      ],
      "weight": 1.8,
      "notes": "Complete inclusion eliminates selection bias from post-hoc exclusion of inconvenient cases"
    },
    {
      "section": "Participant Characteristics",
      "item": "6",
      "description": "Was there clear reporting of the demographics of the participants?",
      "keywords": [
        "age",
        "sex",
        "gender",
        "demographics",
        "baseline characteristics",
        "table 1",
        "mean age",
        "median age",
        "patient characteristics",
        "demographic profile",
        "population characteristics",
        "age range",
        "gender distribution"
      ],
      "weight": 1.2,
      "notes": "Clear demographic reporting allows assessment of generalizability and identification of study population"
    },
    {
      "section": "Participant Characteristics",
      "item": "7",
      "description": "Was there clear reporting of clinical information of the participants?",
      "keywords": [
        "medical history",
        "comorbidities",
        "clinical presentation",
        "symptoms",
        "clinical features",
        "disease severity",
        "stage",
        "clinical characteristics",
        "presenting complaint",
        "prior treatment",
        "risk factors",
        "disease duration"
      ],
      "weight": 1.3,
      "notes": "Clinical context is essential for understanding the cases and their relevance to practice"
    },
    {
      "section": "Outcomes",
      "item": "8",
      "description": "Were the outcomes or follow-up results of cases clearly reported?",
      "keywords": [
        "outcomes",
        "follow-up",
        "results",
        "mortality",
        "survival",
        "complications",
        "recurrence",
        "response rate",
        "clinical outcomes",
        "adverse events",
        "treatment response",
        "long-term outcomes",
        "outcome measures"
      ],
      "weight": 1.8,
      "notes": "Clear outcome reporting is crucial for drawing conclusions about the effectiveness of treatment or disease course"
    },
    {
      "section": "Study Setting",
      "item": "9",
      "description": "Was there clear reporting of the presenting site(s)/clinic(s) demographic information?",
      "keywords": [
        "institution",
        "hospital",
        "medical center",
        "clinic",
        "department",
        "tertiary center",
        "university hospital",
        "study site",
        "healthcare facility",
        "teaching hospital",
        "setting",
        "practice setting",
        "location of study"
      ],
      "weight": 1.1,
      "notes": "Setting information affects generalizability and resource availability for implementing findings"
    },
    {
      "section": "Analysis",
      "item": "10",
      "description": "Was statistical analysis appropriate?",
      "keywords": [
        "descriptive statistics",
        "mean",
        "median",
        "standard deviation",
        "range",
        "interquartile range",
        "frequency",
        "percentage",
        "Kaplan-Meier",
        "statistical analysis",
        "confidence interval",
        "incidence",
        "prevalence"
      ],
      "weight": 1.4,
      "notes": "Appropriate statistical methods ensure valid interpretation of case series data"
    }
  ]
}

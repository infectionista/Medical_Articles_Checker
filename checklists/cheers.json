{
  "name": "CHEERS",
  "full_name": "Consolidated Health Economic Evaluation Reporting Standards",
  "description": "Checklist for reporting health economic evaluation studies (CHEERS 2022)",
  "version": "2022",
  "items": [
    {
      "section": "Title",
      "item": "1",
      "description": "Identify the study as an economic evaluation and specify the interventions being compared",
      "keywords": [
        "economic evaluation",
        "cost-effectiveness",
        "cost-utility analysis",
        "cost-benefit analysis",
        "health economic evaluation",
        "budget impact analysis",
        "cost analysis",
        "economic analysis",
        "intervention comparison",
        "comparing interventions",
        "cost-effectiveness study"
      ],
      "weight": 1.5,
      "notes": "Critical identifier; must appear in title for rapid article identification"
    },
    {
      "section": "Abstract",
      "item": "2",
      "description": "Provide a structured summary including objectives, perspective, setting, methods, results, and conclusions",
      "keywords": [
        "structured abstract",
        "economic evaluation abstract",
        "background methods results",
        "objectives perspective setting",
        "abstract cost-effectiveness",
        "incremental cost-effectiveness ratio",
        "ICER",
        "willingness-to-pay",
        "cost per QALY",
        "cost per LY"
      ],
      "weight": 1.0,
      "notes": "Standard abstract structure; often follows journal guidelines"
    },
    {
      "section": "Introduction",
      "item": "3",
      "description": "Provide an explicit statement of the broader context and study question, its relevance to health policy or practice decisions",
      "keywords": [
        "background and objectives",
        "policy relevance",
        "clinical decision-making",
        "resource allocation",
        "health technology assessment",
        "HTA",
        "decision-making context",
        "healthcare policy",
        "treatment burden",
        "clinical effectiveness"
      ],
      "weight": 0.9,
      "notes": "Introduction nearly always present; focuses on context and rationale"
    },
    {
      "section": "Methods",
      "item": "4",
      "description": "Indicate whether a health economic analysis plan was developed",
      "keywords": [
        "health economic analysis plan",
        "analysis plan",
        "HEAP",
        "pre-specified analysis",
        "analytical protocol",
        "analytical framework",
        "predefined methodology",
        "analytical approach",
        "study protocol",
        "methodological protocol"
      ],
      "weight": 1.2,
      "notes": "Transparency requirement; indicates pre-specification of analyses"
    },
    {
      "section": "Methods",
      "item": "5",
      "description": "Describe characteristics of the study population",
      "keywords": [
        "study population",
        "patient population",
        "population characteristics",
        "demographic characteristics",
        "inclusion criteria",
        "exclusion criteria",
        "eligibility criteria",
        "baseline characteristics",
        "target population",
        "recruited population"
      ],
      "weight": 1.2,
      "notes": "Essential for understanding generalizability"
    },
    {
      "section": "Methods",
      "item": "6",
      "description": "Provide relevant contextual information for the study",
      "keywords": [
        "setting and location",
        "study setting",
        "healthcare system",
        "country context",
        "healthcare setting",
        "clinical setting",
        "primary care",
        "hospital setting",
        "institution",
        "geographic location"
      ],
      "weight": 1.0,
      "notes": "Context affects cost estimates and generalizability"
    },
    {
      "section": "Methods",
      "item": "7",
      "description": "Describe the interventions or strategies being compared",
      "keywords": [
        "intervention comparison",
        "interventions compared",
        "treatment alternatives",
        "comparator intervention",
        "alternative strategy",
        "usual care",
        "standard treatment",
        "intervention description",
        "strategy description",
        "treatment arms"
      ],
      "weight": 1.5,
      "notes": "Critical; must be detailed enough for replication"
    },
    {
      "section": "Methods",
      "item": "8",
      "description": "State the perspective(s) of the analysis",
      "keywords": [
        "perspective of analysis",
        "analytic perspective",
        "healthcare payer",
        "societal perspective",
        "patient perspective",
        "provider perspective",
        "third-party payer",
        "NHS perspective",
        "payer perspective",
        "economic perspective"
      ],
      "weight": 1.5,
      "notes": "Critical; determines which costs are included"
    },
    {
      "section": "Methods",
      "item": "9",
      "description": "State the time horizon for the study",
      "keywords": [
        "time horizon",
        "study period",
        "time frame",
        "analytical horizon",
        "lifetime horizon",
        "follow-up period",
        "study duration",
        "time frame of analysis",
        "years horizon",
        "month follow-up"
      ],
      "weight": 1.3,
      "notes": "Critical; affects which costs and outcomes are captured"
    },
    {
      "section": "Methods",
      "item": "10",
      "description": "Report the discount rate(s) used",
      "keywords": [
        "discount rate",
        "discounting",
